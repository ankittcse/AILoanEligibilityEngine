# Copy this file to .env and replace the values with your Supabase and Gemini/OpenAI credentials
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ... (your Supabase anon public key)

# Optional OpenAI keys
VITE_OPENAI_API_KEY=sk-... (your OpenAI secret key)
VITE_OPENAI_MODEL=gpt-3.5-turbo

# Optional Gemini keys
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY
VITE_GEMINI_MODEL=gemini-1.5-turbo
